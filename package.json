{
  "name": "inklog",
  "version": "1.0.0",
  "description": "A lightweight TypeScript console logger with colored output, message formatting, and automatic line breaking using Chalk.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc"
  },
  "keywords": [
    "logger",
    "typescript logger",
    "console logger",
    "chalk logger",
    "node logger",
    "colored logs",
    "terminal logger",
    "logging utility",
    "debug logger",
    "inklog"
  ],
  "author": "Sushant Chaudhary - csushant224@gmail.com",
  "license": "MIT",
  "type": "commonjs",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sushant14ry/inklog.git/inklog"
  },
  "homepage": "git+https://github.com/sushant14ry/inklog.git/inklog#readme",
  "bugs": {
    "url": "https://github.com/sushant14ry/inklog.git/inklog/issues"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "http-proxy-middleware": "^4.0.0",
    "mongoose": "^9.6.2",
    "morgan": "^1.10.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.9.1",
    "rimraf": "^6.1.3",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.3"
  }
}